# Copy to `tool/dart_defines.env` (gitignored) and fill with your real values.
# Then run: `bash tool/gen_dart_defines_xcconfig.sh`

# RevenueCat public SDK keys (RevenueCat dashboard → Project settings → API keys)
REVENUECAT_IOS_API_KEY=appl_your_public_sdk_key
REVENUECAT_ANDROID_API_KEY=goog_your_public_sdk_key

# Entitlement + offering identifiers (RevenueCat dashboard)
REVENUECAT_PREMIUM_ENTITLEMENT_ID=premium
# Leave blank to use "current" offering
REVENUECAT_OFFERING_ID=

