platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      # prevent Swift compiler from generating module interfaces when
      # using bridging headers, which causes the "unsupported" error.
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'NO'
      # disable library evolution for pods; this suppresses -enable-library-evolution
      config.build_settings['SWIFT_ENABLE_LIBRARY_EVOLUTION'] = 'NO'
    end
  end

  # Also update the main Runner project so the same flags apply when
  # compiling the app's own Swift sources.  Without this the Swift driver
  # still adds -enable-library-evolution and triggers the bridging header
  # error.
  begin
    runner_proj_path = File.join('Runner.xcodeproj')
    if File.exist?(runner_proj_path)
      require 'xcodeproj'
      runner_proj = Xcodeproj::Project.open(runner_proj_path)
      runner_proj.targets.each do |target|
        if target.name == 'Runner'
          target.build_configurations.each do |config|
            config.build_settings['SWIFT_ENABLE_LIBRARY_EVOLUTION'] = 'NO'
            config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'NO'
            # also guard against interface emission explicitly
            config.build_settings['SWIFT_EMIT_MODULE_INTERFACE'] = 'NO'
          end
        end
      end
      runner_proj.save
    end
  rescue => e
    puts "Failed to patch Runner project: #{e}"
  end

  # revenuecat patch from before (unchanged)
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'

    end

  end

  # Xcode/Swift toolchains can introduce an ambiguity between StoreKit and
  # RevenueCat types named `SubscriptionPeriod`. Older PurchasesHybridCommon
  # versions reference it unqualified which fails compilation. This patch is
  # best-effort and only runs when the file exists.
  hybrid_file = File.join(
    installer.sandbox.root,
    'PurchasesHybridCommon',
    'ios',
    'PurchasesHybridCommon',
    'PurchasesHybridCommon',
    'StoreProduct+HybridAdditions.swift'
  )
  if File.exist?(hybrid_file)
    begin
      contents = File.read(hybrid_file)
      # Handle both:
      # 1) Upstream file: `SubscriptionPeriod` (ambiguous)
      # 2) Our older patch: `PurchasesHybridCommon.SubscriptionPeriod` (wrong module)
      patched = contents
        .gsub('PurchasesHybridCommon.SubscriptionPeriod', 'RevenueCat.SubscriptionPeriod')
        .gsub(/(?<!\.)\bSubscriptionPeriod\b/, 'RevenueCat.SubscriptionPeriod')
      if patched != contents
        # CocoaPods may mark sources as read-only. Ensure we can write.
        begin
          File.chmod(0644, hybrid_file)
        rescue
          # Ignore chmod failures; File.write will error and be caught below.
        end
        File.write(hybrid_file, patched)
      end
    rescue => e
      puts "RevenueCat patch skipped: #{e}"
    end
  end
end
